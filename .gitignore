# =====================================================
# 🤖 Claude Local Files (DO NOT COMMIT)
# =====================================================
.claude/settings.local.json
CLAUDE.local.md

# =====================================================
# 🔐 Environment Variables
# =====================================================
.env
.env.*

# =====================================================
# 🔐 Secrets / Credentials (CRITICAL)
# =====================================================
# Firebase / Google service accounts
serviceAccountKey.json
firebase-adminsdk*.json

# Generic credentials
credentials.json
token.json

# Private keys
*.pem
*.key

# =====================================================
# 🚫 IMPORTANT NOTES
# =====================================================
# Do NOT ignore all JSON files — your project uses JSON
# Avoid patterns like *.json (breaks functionality)